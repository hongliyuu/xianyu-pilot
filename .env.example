# Xianyu Pilot production environment template
#
# 通过统一部署入口初始化：
#   ./deploy.sh init
#
# 如需手动配置：复制本文件为 .env，再按需修改。所有 *_FILE 路径指向的密钥文件
# 由 ./deploy.sh init 自动生成到 ./secrets/ 目录，
# secrets 目录权限 0700、文件权限 0644；目录权限阻止其他宿主机用户进入，文件权限用于容器内非 root 用户读取。
# 可选项即使不启用，对应的空文件也必须存在（脚本会自动 touch）。

# ===== Runtime =====
APP_ENV=production
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=12400
# 暴露到公网前请改为实际域名，例如：
# TRUSTED_HOSTS=assistant.example.com,localhost,127.0.0.1,api
TRUSTED_HOSTS=localhost,127.0.0.1,api
TRUSTED_PROXY_IPS=172.30.240.20/32
# 同源浏览器访问无需配置 CORS；如需跨域请用逗号分隔的 HTTPS 白名单，禁止 *
CORS_ALLOWED_ORIGINS=
PUBLIC_BASE_URL=

# ===== Administrator =====
ADMIN_USERNAME=admin
# 首次启动时由脚本为随机管理员密码生成 bcrypt cost 12 hash；明文密码只显示一次。
# 手动生成：docker run --rm python:3.11-slim sh -c "pip install -q bcrypt && python -c \"import bcrypt;print(bcrypt.hashpw(b'YOUR_PASSWORD',bcrypt.gensalt(rounds=12)).decode())\""
ADMIN_PASSWORD_HASH_FILE=./secrets/admin-password-hash

# ===== MySQL =====
MYSQL_DATABASE=xianyu_pilot
MYSQL_APP_USER=xianyu_app
MYSQL_APP_PASSWORD_FILE=./secrets/mysql-app-password
MYSQL_ROOT_PASSWORD_FILE=./secrets/mysql-root-password

# ===== Redis =====
REDIS_PASSWORD_FILE=./secrets/redis-password

# ===== Cryptographic boundaries =====
JWT_SECRET_FILE=./secrets/jwt-secret
COOKIE_CRYPTO_SECRET_FILE=./secrets/cookie-crypto-secret
INTERNAL_API_TOKEN_FILE=./secrets/internal-api-token
JWT_EXPIRATION_MS=43200000
JWT_ISSUER=xianyu-pilot-api
JWT_AUDIENCE=xianyu-pilot-web

# ===== API safety limits =====
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
API_RATE_LIMIT_PER_MINUTE=600
AUDIT_LOG_RETENTION_DAYS=90
# 生产预检强制要求 true；保持默认即可
AUDIT_MUTATION_INTENT_REQUIRED=true
MAX_REQUEST_BODY_BYTES=12582912
MAX_UPLOAD_BYTES=10485760

# ===== Scheduled task worker =====
SCHEDULER_POLL_INTERVAL_SECONDS=15
SCHEDULER_TASK_TIMEOUT_SECONDS=300
SCHEDULER_LEASE_SECONDS=360
SCHEDULER_BATCH_SIZE=20
SCHEDULER_HEARTBEAT_MAX_AGE_SECONDS=60

# ===== Crawler service =====
CRAWLER_JSON_LIMIT=256kb
CRAWLER_RATE_LIMIT_WINDOW_MS=60000
CRAWLER_RATE_LIMIT_MAX=60
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_MAX_SESSIONS=100
CRAWLER_SESSION_TTL_MS=1800000
CRAWLER_OPERATION_TIMEOUT_MS=180000
CRAWLER_MAX_COOKIE_BYTES=65536
CRAWLER_ALLOWED_TARGET_HOSTS=goofish.com,taobao.com
CRAWLER_ALLOWED_ORIGINS=
CRAWLER_FORCE_HEADLESS=true
PLAYWRIGHT_DISABLE_SANDBOX=true

# ===== Optional commercial bridge =====
# 全部留空则禁用商业版桥接，使用本地兜底数据
COMMERCIAL_FRONTEND_URL=
COMMERCIAL_ADMIN_URL=
COMMERCIAL_BACKEND_BASE_URL=
COMMERCIAL_BACKEND_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_ADMIN_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_USER_HEALTH_PATH=/api/health
COMMERCIAL_BACKEND_BRIDGE_PREFIX=/admin-api/open-source-bridge
COMMERCIAL_BACKEND_ACCESS_TOKEN_FILE=./secrets/commercial-backend-access-token
COMMERCIAL_BACKEND_SITE_CODE=open-source
COMMERCIAL_BACKEND_SITE_NAME=open-source
COMMERCIAL_BACKEND_TIMEOUT_SECONDS=15
COMMERCIAL_BACKEND_MUTATION_IDEMPOTENCY_ENABLED=false
COMMERCIAL_BACKEND_PAYMENT_IDEMPOTENCY_ENABLED=false
COMMERCIAL_BACKEND_PAID_AD_PLACEMENT_ENFORCED=false

# ===== Optional AI / RAG providers =====
EMBEDDING_API_KEY_FILE=./secrets/embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
AI_PROVIDER_ENABLED=false
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY_FILE=./secrets/ai-provider-api-key
AI_PROVIDER_MODEL=gpt-4o-mini
AI_PROVIDER_TIMEOUT_SECONDS=30

# ===== Optional integrations =====
AMAP_API_KEY_FILE=./secrets/amap-api-key
XIANYU_MTOP_APP_KEY=34839810

# ===== Update checker =====
GITHUB_REPO=hongliyuu/xianyu-pilot

# ===== Published container images =====
API_IMAGE=ghcr.io/hongliyuu/xianyu-pilot-api:latest
WEB_IMAGE=ghcr.io/hongliyuu/xianyu-pilot-web:latest
CRAWLER_IMAGE=ghcr.io/hongliyuu/xianyu-pilot-crawler:latest

# ===== Optional container resource overrides =====
MYSQL_MEMORY_LIMIT=1g
MYSQL_CPU_LIMIT=1.5
REDIS_MEMORY_LIMIT=512m
REDIS_CPU_LIMIT=0.75
API_MEMORY_LIMIT=1g
API_CPU_LIMIT=2.0
SCHEDULER_MEMORY_LIMIT=1g
SCHEDULER_CPU_LIMIT=1.0
CRAWLER_MEMORY_LIMIT=2g
CRAWLER_CPU_LIMIT=2.0
CRAWLER_SHM_SIZE=512m
WEB_MEMORY_LIMIT=256m
WEB_CPU_LIMIT=0.5
